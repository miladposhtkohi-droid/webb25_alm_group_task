# TODO: setup dockerfile
# 1. Use a small and secure Node image
FROM node:24-alpine

# 2. Create app directory
WORKDIR /app

# 3. Copy package.json first to leverage Docker cache
COPY package*.json ./

# 4. Install only production dependencies
RUN npm install --production

# 5. Copy the rest of the project
COPY . .

# 6. Expose the port your server runs on
EXPOSE 3000

# 7. Start the server
CMD ["node", "src/server.js"]

# 8. Add a health check (optional)
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s \
  CMD curl -f http://localhost:3000/health || exit 1   

# 9. ENV variables for production
ENV NODE_ENV=production